# Pure Kamal deploy (no Rails credentials to fall back on), so everything
# lives in a single 1Password item: Private/sub-store.jalenx.me.
# Do NOT quote ${SECRETS} — kamal's dotenv parser relies on
# shellescape/shellsplit round-tripping the fetched value.
SECRETS=$(kamal secrets fetch --adapter 1password --account my --from Private/pzrshuuhfyvbpfls4h7wutmgee KAMAL_REGISTRY_PASSWORD SUB_STORE_FRONTEND_BACKEND_PATH SUB_STORE_PUSH_SERVICE SSL_CERTIFICATE SSL_PRIVATE_KEY)
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD ${SECRETS})
SUB_STORE_FRONTEND_BACKEND_PATH=$(kamal secrets extract SUB_STORE_FRONTEND_BACKEND_PATH ${SECRETS})
SUB_STORE_PUSH_SERVICE=$(kamal secrets extract SUB_STORE_PUSH_SERVICE ${SECRETS})
SSL_CERTIFICATE=$(kamal secrets extract SSL_CERTIFICATE ${SECRETS})
SSL_PRIVATE_KEY=$(kamal secrets extract SSL_PRIVATE_KEY ${SECRETS})
